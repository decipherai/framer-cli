{
  "name": "framer-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "framer-cli": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "Decipher",
  "license": "MIT",
  "description": "Agent-friendly CLI wrapper around the Framer Server API.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decipherai/framer-cli.git"
  },
  "bugs": {
    "url": "https://github.com/decipherai/framer-cli/issues"
  },
  "homepage": "https://github.com/decipherai/framer-cli#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "framer-api": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.4.3"
  },
  "keywords": [
    "framer",
    "framer-api",
    "cms",
    "cli",
    "agent",
    "automation"
  ]
}
